# Auth0 (v4 SDK)
AUTH0_SECRET=                        # generate with: openssl rand -hex 32
AUTH0_DOMAIN=                        # e.g. yourapp.us.auth0.com
AUTH0_CLIENT_ID=                     # from Auth0 dashboard
AUTH0_CLIENT_SECRET=                 # from Auth0 dashboard
APP_BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/outfitted

# Cloudinary
CLOUDINARY_CLOUD_NAME=               # from Cloudinary dashboard
CLOUDINARY_API_KEY=                  # from Cloudinary dashboard
CLOUDINARY_API_SECRET=               # from Cloudinary dashboard

# Google Gemini
GEMINI_API_KEY=                      # from Google AI Studio

# Serper (Google Shopping search — https://serper.dev)
SERPER_API_KEY=

# Replicate (virtual try-on + background removal)
REPLICATE_API_TOKEN=

# OpenRouter
OPENROUTER_API_KEY=

# Solana (devnet payer keypair — JSON array of 64 numbers)
# Generate:  solana-keygen new --outfile payer.json
# Fund:      solana airdrop 2 <PUBKEY> --url devnet
SOLANA_PAYER_PRIVATE_KEY=

# React Bits Pro
REACTBITS_LICENSE_KEY=
